{
  "compilerOptions": {
    "baseUrl": "./src",
    "target": "ES2020",                     // Modern JS features
    "module": "CommonJS",                   // Node.js module system
    "moduleResolution": "node",             // Resolve node_modules
    "esModuleInterop": true,                // Allow import of CommonJS modules
    "forceConsistentCasingInFileNames": true,
    "strict": true,                         // Enable all strict type checks
    "skipLibCheck": true,                   // Skip type checking for node_modules
    "outDir": "dist",                       // Compiled JS output
    "rootDir": "src",                       // Source TS files
    "resolveJsonModule": true,              // Allow importing JSON (credentials.json)
    "noImplicitAny": false                   // Optional: allow implicit any
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}