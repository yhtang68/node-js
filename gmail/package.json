{
  "name": "linkedin-job-review",
  "version": "1.0.0",
  "description": "Fetch LinkedIn job alert emails from Gmail, deduplicate, and generate HTML review page",
  "main": "dist/index.js",
  
  "keywords": [
    "gmail",
    "linkedin",
    "jobs",
    "typescript",
    "nodejs"
  ],

  "author": "Yuan-Hsun Tang (Andy)",
  "license": "MIT",
  
  "dependencies": {
    "googleapis": "^118.0.0"
  },

  "devDependencies": {
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },

  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "manageToken": "ts-node src/manageToken.ts",
    "fetchJobs": "ts-node src/fetchJobs.ts",
    "generateHTML": "ts-node src/generateHTML.ts",
    "reviewJobs": "ts-node src/index.ts"
  }
}