{
  "name": "linkedin-job-review",
  "version": "1.0.0",
  "description": "Fetch LinkedIn job alert emails from Gmail, deduplicate, and generate HTML review page",
  "main": "dist/index.js",
  
  "keywords": [
    "gmail",
    "linkedin",
    "jobs",
    "typescript",
    "nodejs"
  ],

  "author": "Yuan-Hsun Tang (Andy)",
  "license": "MIT",
  
  "dependencies": {
    "googleapis": "^171.4.0"
  },

  "devDependencies": {
    "nodemon": "^3.0.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },

  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "del:results": "rimraf Results",
    "del:packages": "rimraf node_modules",
    "manageToken": "ts-node src/manageToken.ts",
    "generateReview": "ts-node src/generateReview.ts",
    "generateFilteredReview": "ts-node src/generateFilteredReview.ts",
    "reviewJobs": "ts-node src/index.ts"
  }
}
